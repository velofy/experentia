  "fonts": {
    "Geist Sans": {
      "type": "sans-serif (Swiss/International Typographic Style, geometric)",
      "weights": [
        "Thin 100",
        "ExtraLight 200",
        "Light 300",
        "Regular 400",
        "Medium 500",
        "SemiBold 600",
        "Bold 700",
        "ExtraBold 800",
        "Black 900"
      ],
      "styles": "Upright + matching Italics for every weight; variable font wght 100..900",
      "use": "body copy, headings, logos, posters, display",
      "google_fonts_family": "Geist",
      "google_fonts_css": "https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap",
      "npm": "geist -> import { GeistSans } from 'geist/font/sans' (CSS var --font-geist-sans)"
    },
    "Geist Mono": {
      "type": "monospace partner to Sans",
      "weights": [
        "Thin 100",
        "ExtraLight 200",
        "Light 300",
        "Regular 400",
        "Medium 500",
        "SemiBold 600",
        "Bold 700",
        "ExtraBold 800",
        "Black 900"
      ],
      "use": "code editors, terminals, diagrams, code UI",
      "google_fonts_family": "Geist Mono",
      "google_fonts_css": "https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&display=swap",
      "npm": "import { GeistMono } from 'geist/font/mono' (CSS var --font-geist-mono)"
    },
    "Geist Pixel": {
      "type": "pixel/bitmap display typeface",
      "variants": [
        "Square",
        "Grid",
        "Circle",
        "Triangle",
        "Line"
      ],
      "variable_axis": {
        "vercel_font_page_name": "ELSH (selects the 5 pixel shapes in the variable-font playground)",
        "oss_repo_axis_tag": "PXSH",
        "oss_repo_axis_name": "Pixel Shape",
        "note": "vercel.com/font labels the shape axis 'ELSH'; the open-source geist-pixel-font repo defines the custom axis as tag PXSH / name 'Pixel Shape'. A code search for 'ELSH' in the repo returns 0 hits. The npm package ships the 5 as separate static NextFontWithVariable exports."
      },
      "use": "display only: headlines, logos, decorative pixel contexts",
      "google_fonts_family": "Geist Pixel",
      "google_fonts_css": "https://fonts.googleapis.com/css2?family=Geist+Pixel&display=swap",
      "npm_exports": {
        "GeistPixelSquare": "--font-geist-pixel-square",
        "GeistPixelGrid": "--font-geist-pixel-grid",
        "GeistPixelCircle": "--font-geist-pixel-circle",
        "GeistPixelTriangle": "--font-geist-pixel-triangle",
        "GeistPixelLine": "--font-geist-pixel-line"
      },
      "npm_import": "import { GeistPixelSquare, GeistPixelGrid, GeistPixelCircle, GeistPixelTriangle, GeistPixelLine } from 'geist/font/pixel'"
